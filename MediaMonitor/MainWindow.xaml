<Window x:Class="MediaMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:MediaMonitor.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Трекер медиа-контента" Height="800" Width="1090"
        MinHeight="560" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        Icon="/лого3.png"
        WindowStyle="None"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                             ResizeBorderThickness="6"
                             CornerRadius="0"
                             GlassFrameThickness="0"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:TypeToColorConverter x:Key="TypeToColor"/>
        <conv:RatingToStringConverter x:Key="RatingToString"/>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PercentToGridLengthConverter x:Key="PctToStar"/>
        <conv:IsFilterSelectedConverter x:Key="IsFilterSelected"/>
        <conv:TagsContainConverter x:Key="TagsContain"/>
        <conv:CollectionToVisibilityConverter x:Key="CollectionToVisibility"/>


        <Style x:Key="FilterTabBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusTabBtn" TargetType="Button"
               BasedOn="{StaticResource FilterTabBtn}">
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IsFilterSelected}">
                            <Binding Path="SelectedStatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TypeTabBtn" TargetType="Button"
        BasedOn="{StaticResource FilterTabBtn}">
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IsFilterSelected}">
                            <Binding Path="SelectedTypeFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#8AEFD8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TagFilterBtn" TargetType="Button"
        BasedOn="{StaticResource FilterTabBtn}">
            <Setter Property="Margin" Value="0,6,6,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource TagsContain}">
                            <Binding Path="DataContext.SelectedTags" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#8AEFD8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteFilterBtn" TargetType="Button"
        BasedOn="{StaticResource FilterTabBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowFavoritesOnly}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#FFD700"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardIconBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#AA000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#79baab"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопки системного титульного бара -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Узкие иконки-кнопки в титульном баре (импорт/экспорт/тема) -->
        <Style x:Key="TitleBarIconBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Width" Value="38"/>
        </Style>

        <DataTemplate x:Key="MediaCardTemplate">
            <Border Width="170" Margin="6" CornerRadius="10"
                    Background="{DynamicResource CardBackgroundBrush}" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="4"
                                      Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Border Height="200" CornerRadius="10,10,0,0" ClipToBounds="True">
                        <Grid>
                            <Rectangle Fill="#1A1A2E"/>
                            <TextBlock Text="🎬" FontSize="42" Foreground="#333"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image Source="{Binding PosterUrl}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Rectangle VerticalAlignment="Bottom" Height="60">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000"   Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <!-- Рейтинг -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background ="#BB000000" CornerRadius="5"
                                    Margin="6,6,0,0" Padding="7,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="★"  Foreground="#FFD700"
                                               FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Rating,
                                                      Converter={StaticResource RatingToString}}"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               Margin="3,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Статус -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="{Binding Status,
                                                 Converter={StaticResource StatusToColor}}"
                                    CornerRadius="5" Margin="0,7,6,0" Padding="5,2">
                                <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="—"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Planned">
                                                    <Setter Property="Text" Value="В ПЛАНАХ"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Watching">
                                                    <Setter Property="Text" Value="В ПРОЦЕССЕ"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Dropped">
                                                    <Setter Property="Text" Value="БРОШЕНО"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Text" Value="ЗАВЕРШЕНО"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Тип -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    Background="{Binding Type,
                                                 Converter={StaticResource TypeToColor}}"
                                    CornerRadius="5" Margin="6,0,0,6" Padding="5,2">
                                <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="—"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Movie">
                                                    <Setter Property="Text" Value="ФИЛЬМ"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Series">
                                                    <Setter Property="Text" Value="СЕРИАЛ"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Anime">
                                                    <Setter Property="Text" Value="АНИМЕ"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Game">
                                                    <Setter Property="Text" Value="ИГРА"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Other">
                                                    <Setter Property="Text" Value="ДРУГОЕ"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Кнопки избранное / редактировать / удалить -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,6,6">
                                <Button Style="{StaticResource CardIconBtn}" Margin="0,0,3,0"
                                        ToolTip="В избранное"
                                        Command="{Binding DataContext.ToggleFavoriteCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="☆"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Text" Value="★"/>
                                                        <Setter Property="Foreground" Value="#FFD700"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource CardIconBtn}" Margin="0,0,3,0"
                                        Command="{Binding DataContext.EditItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="✏" FontSize="11" Foreground="White"/>
                                </Button>
                                <Button Style="{StaticResource CardIconBtn}"
                                        Command="{Binding DataContext.DeleteItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="🗑" FontSize="11" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Margin="10,8,10,10">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ДОБАВЛЕНО"
                                           FontSize="8" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DateAdded, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Visibility="{Binding CompletionDate,
                                                     Converter={StaticResource NullToCollapsed}}">
                                <TextBlock Text="ЗАВЕРШЕНО"
                                           FontSize="8" Foreground="#556B2F" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CompletionDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           FontSize="9" Foreground="#556B4F"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding Comment}"
                                   FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0"
                                   TextTrimming="CharacterEllipsis" MaxHeight="34"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Comment,
                                                Converter={StaticResource NullToCollapsed}}"/>
                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,6,0,0"
                                      Visibility="{Binding Tags, Converter={StaticResource CollectionToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                            CornerRadius="8" Padding="6,2" Margin="0,0,4,4">
                                        <TextBlock Text="{Binding}" FontSize="9"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="10" Margin="10"
            Background="{DynamicResource WindowBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect x:Name="RootShadow" BlurRadius="20" ShadowDepth="0"
                              Opacity="0.5" Color="Black"/>
        </Border.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кастомный титульный бар -->
        <Border x:Name="TitleBarBorder" Grid.Row="0" Height="40" CornerRadius="10,10,0,0"
                Background="{DynamicResource TitleBarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="14,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="Трекер медиа-контента" Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ImportButton" Style="{StaticResource TitleBarIconBtn}"
                            Command="{Binding ImportCommand}" ToolTip="Импорт коллекции (JSON)">
                        <md:PackIcon Kind="Import" Width="15" Height="15"/>
                    </Button>
                    <Button x:Name="ExportButton" Style="{StaticResource TitleBarIconBtn}"
                            Command="{Binding ExportCommand}" ToolTip="Экспорт коллекции (JSON)">
                        <md:PackIcon Kind="Export" Width="15" Height="15"/>
                    </Button>
                    <Border Width="1" Margin="4,10" Background="{DynamicResource ContentDividerBrush}"/>
                    <Button x:Name="MinimizeButton" Style="{StaticResource TitleBarBtn}"
                            Click="MinimizeButton_Click" ToolTip="Свернуть">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarBtn}"
                            Click="MaximizeButton_Click" ToolTip="Развернуть">
                        <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource TitleBarCloseBtn}"
                            Click="CloseButton_Click" ToolTip="Закрыть">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель со статистикой -->
        <Border x:Name="SidebarBorder" Grid.Column="0" CornerRadius="0,0,0,10"
                Background="{DynamicResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Логотипчик -->
                <Border Grid.Row="0" Padding="18,20,18,14"
                            BorderBrush ="#222" BorderThickness ="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="SidebarLogoImage" Source="/лого3.png" Width="50" Height="50"/>
                        <TextBlock Text="Твой трекер"
                                   FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}" 
                                   Margin="10,25,10,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="18,0,18,18">

                        <TextBlock Text="Статистика"
                                   FontSize="17" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" 
                                   Margin="0,0,0,12"/>

                        <!-- Всего -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text ="{Binding Statistics.TotalItems}"
                                       FontSize="40" FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="объектов&#x0a;всего"
                                       FontSize="11" Foreground="{DynamicResource MutedTextBrush}" 
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Завершено -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Завершено" FontSize="12"  Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text ="{Binding Statistics.CompletedCount}"
                                       FontSize="12" Foreground="{DynamicResource StatusCompletedTextBrush}" FontWeight="Bold"/>
                        </Grid>
                        <Grid Height="4" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Statistics.CompletedPercent,
                                                          Converter={StaticResource PctToStar}}"/>
                                <ColumnDefinition Width="{Binding Statistics.CompletedPercent,
                                                         Converter={StaticResource PctToStar}, ConverterParameter=inverse}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#556B4F" CornerRadius="2"/>
                            <Border Grid.Column="1" Background="{DynamicResource TrackBackgroundBrush}" CornerRadius="2"/>
                        </Grid>

                        <!-- В процессе -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="В процессе" FontSize="12"  Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text ="{Binding Statistics.WatchingCount}"
                                       FontSize="12" Foreground="{DynamicResource StatusWatchingTextBrush}" FontWeight="Bold"/>
                        </Grid>
                        <Grid Height="4" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Statistics.WatchingPercent,
                                                          Converter={StaticResource PctToStar}}"/>
                                <ColumnDefinition Width="{Binding Statistics.WatchingPercent,
                                                         Converter={StaticResource PctToStar}, ConverterParameter=inverse}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#7DB9E8" CornerRadius="2"/>
                            <Border Grid.Column="1" Background="{DynamicResource TrackBackgroundBrush}" CornerRadius="2"/>
                        </Grid>

                        <!-- В планах -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="В планах" FontSize="12"  Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text ="{Binding Statistics.PlannedCount}"
                                       FontSize="12" Foreground="{DynamicResource StatusPlannedTextBrush}" FontWeight="Bold"/>
                        </Grid>
                        <Grid Height="4" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Statistics.PlannedPercent,
                                                          Converter={StaticResource PctToStar}}"/>
                                <ColumnDefinition Width="{Binding Statistics.PlannedPercent,
                                                         Converter={StaticResource PctToStar}, ConverterParameter=inverse}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#C596D6" CornerRadius="2"/>
                            <Border Grid.Column="1" Background="{DynamicResource TrackBackgroundBrush}" CornerRadius="2"/>
                        </Grid>

                        <!-- Брошено -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Брошено" FontSize="12"  Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text ="{Binding Statistics.DroppedCount}"
                                       FontSize="12" Foreground="{DynamicResource StatusDroppedTextBrush}" FontWeight="Bold"/>
                        </Grid>
                        <Grid Height="4" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Statistics.DroppedPercent,
                                                          Converter={StaticResource PctToStar}}"/>
                                <ColumnDefinition Width="{Binding Statistics.DroppedPercent,
                                                         Converter={StaticResource PctToStar}, ConverterParameter=inverse}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F0806E" CornerRadius="2"/>
                            <Border Grid.Column="1" Background="{DynamicResource TrackBackgroundBrush}" CornerRadius="2"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,14"/>

                        <!-- Средний рейтинг и пересмотры -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource SurfaceElevatedBrush}"
                                    CornerRadius="8" Padding="10,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Width="59">
                                        <TextBlock Text="★ " Foreground="#FFD700" FontSize="14"/>
                                        <TextBlock Text="{Binding Statistics.AverageRating, StringFormat={}{0:0.#}}"
                                                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="СР.РЕЙТИНГ" FontSize="8"
                                               Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium"
                                               Margin="0,2,0,0" Height="12" Width="46"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource SurfaceElevatedBrush}"
                                    CornerRadius="8" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Statistics.TotalRewatches}"
                                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Width="65"/>
                                    <TextBlock Text="ПЕРЕСМОТРЕНО" FontSize="8"
                                               Foreground="{DynamicResource MutedTextBrush}" FontWeight="Medium"
                                               Margin="0,2,0,0" Height="14" Width="68"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,10"/>

                        <TextBlock Text="По типам" FontSize="11" FontWeight="Bold" 
                                   Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding TypeStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Count}"
                                                       FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                                        </Grid>
                                        <Grid Height="4" Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding Percent,
                                                    Converter={StaticResource PctToStar}}"/>
                                                <ColumnDefinition Width="{Binding Percent,
                                                    Converter={StaticResource PctToStar}, ConverterParameter=inverse}"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding Color}"
                                                    CornerRadius="2"/>
                                            <Border Grid.Column="1" Background="{DynamicResource TrackBackgroundBrush}"
                                                    CornerRadius="2"/>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Основая область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Фильтр по статусу -->
            <Border Grid.Row="0" BorderBrush="{DynamicResource ContentDividerBrush}" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="12,0,12,0">
                        <Button Tag="Все" Content="Все"
                                CommandParameter="Все"
                                Command="{Binding SetStatusFilterCommand}"
                                Style="{StaticResource StatusTabBtn}"/>
                        <Button Tag="В планах" Content="В планах"
                                CommandParameter="В планах"
                                Command="{Binding SetStatusFilterCommand}"
                                Style="{StaticResource StatusTabBtn}"/>
                        <Button Tag="В процессе" Content="В процессе"
                                CommandParameter="В процессе"
                                Command="{Binding SetStatusFilterCommand}"
                                Style="{StaticResource StatusTabBtn}"/>
                        <Button Tag="Завершено" Content="Завершено"
                                CommandParameter="Завершено"
                                Command="{Binding SetStatusFilterCommand}"
                                Style="{StaticResource StatusTabBtn}"/>
                        <Button Tag="Брошено" Content="Брошено"
                                CommandParameter="Брошено"
                                Command="{Binding SetStatusFilterCommand}"
                                Style="{StaticResource StatusTabBtn}"/>
                        <Border Width="1" Margin="6,8" Background="{DynamicResource ContentDividerBrush}"/>
                        <Button Content="★ Избранное"
                                Command="{Binding ToggleFavoritesFilterCommand}"
                                Style="{StaticResource FavoriteFilterBtn}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Фильтр по типу-->
            <Border Grid.Row="1" BorderBrush="{DynamicResource ContentDividerBrush}" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="12,0,12,0">
                        <Button Tag="Все типы" Content="Все типы"
                                CommandParameter="Все типы"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                        <Button Tag="Фильм" Content="🎞 Фильм"
                                CommandParameter="Фильм"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                        <Button Tag="Сериал" Content="💻 Сериал"
                                CommandParameter="Сериал"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                        <Button Tag="Аниме" Content="🎐 Аниме"
                                CommandParameter="Аниме"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                        <Button Tag="Игра" Content="👾 Игра"
                                CommandParameter="Игра"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                        <Button Tag="Другое" Content="🛋 Другое"
                                CommandParameter="Другое"
                                Command="{Binding SetTypeFilterCommand}"
                                Style="{StaticResource TypeTabBtn}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Фильтр по тегам -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource ContentDividerBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding AllTags, Converter={StaticResource CollectionToVisibility}}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl Margin="12,0,12,0" ItemsSource="{Binding AllTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Tag="{Binding}"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.ToggleTagFilterCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Style="{StaticResource TagFilterBtn}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Поиск и сортировка-->
            <Grid Grid.Row="3" Margin="16,10,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SearchBoxBackgroundBrush}" CornerRadius="8"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource MutedTextBrush}"
                           Margin="12,0,6,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}" FontSize="13"
                                 VerticalAlignment="Center" Height="38"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 SelectionBrush="#8AEFD8"
                                 md:HintAssist.Hint="Поиск по названию..."
                                 md:HintAssist.Foreground="{DynamicResource MutedTextBrush}"
                                 md:TextFieldAssist.DecorationVisibility="Hidden"/>
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort}"
                          Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"
                          Style="{StaticResource MaterialDesignComboBox}"/>
            </Grid>

            <!-- Карточки -->
            <Grid Grid.Row="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="11,0,11,64">
                    <ItemsControl ItemsSource="{Binding FilteredItems}"
                                  ItemTemplate="{StaticResource MediaCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Пустое состояние -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}">
                    <TextBlock Text="Ничего не найдено ¯\_(ツ)_/¯" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <!-- Кнопка Добавить-->
                <Button Command="{Binding AddItemCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,20,20" Width="52" Height="52"
                        ToolTip="Добавить"
                        Style="{StaticResource MaterialDesignFloatingActionButton}"
                        Background="#8AEFD8" BorderBrush="#8AEFD8">
                    <TextBlock Text="+" FontSize="35" FontWeight="SemiBold"
                               Foreground="#00594c" Margin="0,-8,0,0"/>
                </Button>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
