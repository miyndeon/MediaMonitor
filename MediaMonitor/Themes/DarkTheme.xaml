<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#313131"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#262626"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#262626"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#3B3B3B"/>
    <SolidColorBrush x:Key="SearchBoxBackgroundBrush" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="TrackBackgroundBrush" Color="#444444"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#222222"/>
    <SolidColorBrush x:Key="ContentDividerBrush" Color="#404040"/>
    <SolidColorBrush x:Key="HoverSurfaceBrush" Color="#3D3D3D"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#888888"/>

    <!-- Акцент и статусные цвета текста: в тёмной теме совпадают с исходными -->
    <SolidColorBrush x:Key="AccentTextBrush" Color="#8AEFD8"/>
    <SolidColorBrush x:Key="StatusCompletedTextBrush" Color="#556B4F"/>
    <SolidColorBrush x:Key="StatusWatchingTextBrush" Color="#80B0E8"/>
    <SolidColorBrush x:Key="StatusPlannedTextBrush" Color="#F8CABA"/>
    <SolidColorBrush x:Key="StatusDroppedTextBrush" Color="#D17089"/>

</ResourceDictionary>
