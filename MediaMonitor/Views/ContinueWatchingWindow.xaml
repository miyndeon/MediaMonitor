<Window x:Class="MediaMonitor.Views.ContinueWatchingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Продолжить просмотр?"
        Width="300" Height="106"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        TextElement.Foreground="White"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Border Background="#2A2A2A" CornerRadius="12" Padding="10"
            BorderBrush="#3A3A3A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="54"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Мини-постер -->
            <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True">
                <Grid>
                    <Rectangle Fill="#111"/>
                    <TextBlock Text="🎬" FontSize="18" Foreground="#333"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding PosterUrl}" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
            </Border>

            <!-- Текст + кнопки -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,18,0">
                <TextBlock Text="▶ Не забыли досмотреть?" FontSize="10" Foreground="#8AEFD8"/>
                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold"
                           Foreground="White" TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="▶  Продолжить" Click="ContinueButton_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#556B4F" BorderBrush="#8AEFD8" Foreground="White"
                            FontSize="10" Height="26" Padding="8,0"/>
                    <Button Content="Позже" Click="CloseButton_Click" Margin="8,0,0,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#999" FontSize="10" Height="26" Padding="8,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Крестик закрытия -->
            <Button Grid.Column="2" Content="✕" Click="CloseButton_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="20" Height="20" Padding="0" FontSize="9"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#777" Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
