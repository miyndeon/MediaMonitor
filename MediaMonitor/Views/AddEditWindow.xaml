<Window x:Class="MediaMonitor.Views.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:MediaMonitor.Converters"
        xmlns:validation="clr-namespace:MediaMonitor.Validation"
        Title="Добавить / Изменить"
        Width="520" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#262626"
        TextElement.Foreground="White"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>

        <Style x:Key="ValidatedTextBox" TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <StackPanel>
                            <AdornedElementPlaceholder/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#E5766B"/>
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self},
                                    Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="27*"/>
            <ColumnDefinition Width="38*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0" Grid.ColumnSpan="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,20,24,8" Margin="10,10,10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Постер + URL + поиск -->
                <StackPanel Grid.Column="0">
                    <Border x:Name="PosterDropBorder" Height="196" CornerRadius="8" ClipToBounds="True"
                            AllowDrop="True"
                            DragEnter="PosterDropBorder_DragEnter"
                            DragLeave="PosterDropBorder_DragLeave"
                            Drop="PosterDropBorder_Drop">
                        <Grid>
                            <Rectangle Fill="#111"/>
                            <TextBlock Text="🎬" FontSize="36" Foreground="#333"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image Source="{Binding PosterUrl}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Border x:Name="PosterDropOverlay" Background="#AA8AEFD8" Visibility="Collapsed">
                                <TextBlock Text="Отпустите, чтобы вставить постер"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#00594c"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="10"/>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBox Text="{Binding PosterUrl, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,8,0,0" FontSize="10"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             md:HintAssist.Hint="URL постера"
                             md:HintAssist.Foreground="#555"
                             Background="#252525" Foreground="White" CaretBrush="White"
                             TextWrapping="Wrap" MaxLength="500"/>

                    <TextBlock Text="{Binding SearchPosterStatus}"
                               FontSize="10" Foreground="#8AEFD8"
                               TextWrapping="Wrap" Margin="0,5,0,0"
                               Visibility="{Binding SearchPosterStatus,
                                            Converter={StaticResource NullToCollapsed}}"/>
                    <Button
                            Command="{Binding SearchPosterCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#8AEFD8" BorderBrush="#333"
                            FontSize="11" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Magnify" Width="14" Height="14"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text=" Найти постер" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,4,0,0"
                                 Foreground="#8AEFD8"
                                 Visibility="{Binding IsSearchPoster,
                                              Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">

                    <!-- Название -->
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             md:HintAssist.Hint="Название *"
                             md:HintAssist.Foreground="#555"
                             Background="#252525" Foreground="White" CaretBrush="White"
                             FontSize="14" FontWeight="SemiBold"
                             Margin="0,6,0,14" Height="50"/>

                    <!-- Тип -->
                    <ComboBox ItemsSource="{Binding MediaTypes}"
                              SelectedItem="{Binding Type}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              md:HintAssist.Hint="Тип"
                              md:HintAssist.Foreground="#555"
                              Background="#252525" Foreground="White"
                              FontSize="13" Margin="0,0,0,14" Height="47">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Movie">
                                                    <Setter Property="Text" Value="🎞  Фильм"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Series">
                                                    <Setter Property="Text" Value="💻  Сериал"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Anime">
                                                    <Setter Property="Text" Value="🎐  Аниме"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Game">
                                                    <Setter Property="Text" Value="👾  Игра"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Other">
                                                    <Setter Property="Text" Value="🛋  Другое"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Статус -->
                    <ComboBox ItemsSource="{Binding MediaStatuses}"
                              SelectedItem="{Binding Status}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              md:HintAssist.Hint="Статус"
                              md:HintAssist.Foreground="#555"
                              Background="#252525" Foreground="White"
                              FontSize="13" Margin="0,0,0,14" Height="48">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Planned">
                                                    <Setter Property="Text" Value="📌  В планах"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Watching">
                                                    <Setter Property="Text" Value="▶  В процессе"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Dropped">
                                                    <Setter Property="Text" Value="⛔  Брошено"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Completed">
                                                    <Setter Property="Text" Value="✅  Завершено"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Избранное -->

                    <!-- Рейтинг -->
                    <TextBlock Text="Рейтинг" FontSize="11" Foreground="#666"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding Rating}"
                                Minimum="0" Maximum="10"
                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                Style="{StaticResource MaterialDesignSlider}"
                                Foreground="#8AEFD8"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Rating, StringFormat={}{0:0.#}}"
                                   FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Пересмотрено -->
                    <TextBox Style="{StaticResource ValidatedTextBox}"
                             md:HintAssist.Hint="Пересмотров (число)"
                             md:HintAssist.Foreground="#555"
                             Background="#252525" Foreground="White" CaretBrush="White"
                             FontSize="13" Margin="0,0,0,14" Height="48">
                        <TextBox.Text>
                            <Binding Path="RewatchCount" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <validation:NonNegativeIntegerValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <!-- Дата добавления -->
                    <TextBlock Text="Дата добавления"
                               FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding DateAdded, Mode=TwoWay}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                md:HintAssist.Hint="дд.мм.гггг"
                                md:HintAssist.Foreground="#555"
                                Background="#252525" Foreground="White"
                                FontSize="13" Margin="0,0,0,14"
                                FirstDayOfWeek="Monday" Height="48"/>

                    <!-- Дата завершения (только если статус = Завершено) -->
                    <StackPanel Visibility="{Binding IsCompleted,
                                             Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Дата завершения"
                                   FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding CompletionDate, Mode=TwoWay}"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    md:HintAssist.Hint="дд.мм.гггг"
                                    md:HintAssist.Foreground="#555"
                                    Background="#252525" Foreground="White"
                                    FontSize="13" Margin="0,0,0,14"
                                    FirstDayOfWeek="Monday" Height="48"/>
                    </StackPanel>

                    <!-- Комментарий -->
                    <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             md:HintAssist.Hint="Комментарий (до 1000 символов)"
                             md:HintAssist.Foreground="#555"
                             Background="#252525" Foreground="White" CaretBrush="White"
                             FontSize="12"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="48" MaxLength="1000"
                             VerticalScrollBarVisibility="Auto" Height="53"/>

                    <!-- Теги / жанры -->
                    <TextBlock Text="Теги / жанры" FontSize="11" Foreground="#666"
                               Margin="0,14,0,4"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="29*"/>
                            <RowDefinition Height="21*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TagInputBox" Grid.Column="0"
                                 Text="{Binding NewTagText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 md:HintAssist.Hint="Например: комедия, избранное.."
                                 md:HintAssist.Foreground="#555"
                                 Background="#252525" Foreground="White" CaretBrush="White"
                                 FontSize="12" Grid.RowSpan="2">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddTagCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="Добавить"
                                Command="{Binding AddTagCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#8AEFD8" BorderBrush="#333"
                                FontSize="11" Grid.ColumnSpan="2" Margin="8,9,0,9" Grid.RowSpan="2"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3B3B3B" CornerRadius="12"
                                        Padding="8,3" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <Button Content="✕" Margin="6,0,0,0" Padding="0"
                                                Width="14" Height="14"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#AAAAAA" Cursor="Hand" FontSize="9"
                                                Command="{Binding DataContext.RemoveTagCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки снизу -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#1E1E1E"
                BorderBrush="#222" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="24,12,24,16">
                <Button Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#777" BorderBrush="#333"
                        Background="#222"
                        Width="100" Height="36" Margin="0,0,12,0"/>
                <Button Content="💾  Сохранить"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#556B4F" BorderBrush="#8AEFD8"
                        Foreground="White" Width="130" Height="36"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
